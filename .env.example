# Vida 2.0 — variables de entorno (ejemplo)
#
# Copia este archivo a `.env.local` y completa los valores reales.
# `.env.local` está ignorado por Git y NUNCA debe subirse al repositorio.
# Todas estas variables se usan solo en el servidor: claves, tokens y secretos
# nunca deben llegar al navegador ni al bundle del cliente.
#
# --- Clasificación para Vercel (Fase 7A / Preview) ---
# Preview / Production futura: configurar en el panel de Vercel (valores reales).
# Solo desarrollo local: NO configurar en Vercel.
# Opcionales: solo si se necesita diagnóstico local.
# Nunca subir a Vercel: redirect URI local de Calendar OAuth, traces, tokens temporales.
#
# No inventar AUTH_URL / NEXTAUTH_URL: Auth.js v5 con AUTH_TRUST_HOST=true
# resuelve el host de la petición (localhost o *.vercel.app).

# =============================================================================
# Google Sheets (Preview + Production futura)
# =============================================================================
# Origen de datos: "mock" (por defecto en local) o "google".
DATA_SOURCE=mock

# Cuenta de servicio de Google con acceso de LECTURA/escritura acotada al Sheet DEV.
GOOGLE_SERVICE_ACCOUNT_EMAIL=vida-2-0-dev@tu-proyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio (una sola línea con \n).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...clave-de-ejemplo...\n-----END PRIVATE KEY-----\n"

# Único Spreadsheet ID permitido (Sheet DEV). No usar IDs de producción.
GOOGLE_SHEETS_DEV_ID=1TBrEQuocPSNv9SradWea2YWQtMpOEIsHHNRJe0YACdY

# =============================================================================
# Notion — solo lectura (Preview + Production futura)
# =============================================================================
# Origen: "mock" (por defecto) o "notion".
NOTION_DATA_SOURCE=mock

# Token de integración interna (solo servidor).
NOTION_API_TOKEN=secret_ejemplo_no_usar_en_produccion

# Data source IDs canónicos (lista blanca): Tareas / Proyectos / Áreas.
NOTION_TASKS_DATA_SOURCE_ID=a19c1f00-7c4b-4920-ae8a-63d3d4e2525a
NOTION_PROJECTS_DATA_SOURCE_ID=a7b11d6e-f324-4fc7-af71-d2d89da71d28
NOTION_AREAS_DATA_SOURCE_ID=9f166408-d1b0-4bdf-a9f4-9c6801d8b750

# =============================================================================
# Google Calendar — solo lectura (Preview + Production futura)
# =============================================================================
# Origen: "mock" (por defecto) o "google".
# OAuth INDEPENDIENTE del login de Auth.js. No reutilices AUTH_GOOGLE_*.
GOOGLE_CALENDAR_DATA_SOURCE=mock

GOOGLE_CALENDAR_CLIENT_ID=1234567890-calendar.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=ejemplo_calendar_client_secret_no_real

# Refresh token ya obtenido offline (runtime). Solo servidor.
GOOGLE_CALENDAR_REFRESH_TOKEN=ejemplo_refresh_token_no_real

# Lista de calendar IDs autorizados (sin descubrimiento global).
GOOGLE_CALENDAR_IDS=primary

GOOGLE_CALENDAR_TIMEZONE=America/Argentina/Cordoba

# --- Solo desarrollo local (NO configurar en Vercel) ---
# Usada únicamente por /api/calendar/oauth/start y /callback para obtener el
# refresh token en localhost. Esas rutas están bloqueadas en production/VERCEL
# y fuera de localhost/127.0.0.1. El runtime de lectura Calendar NO la necesita.
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/oauth/callback

# =============================================================================
# Auth.js / Google login (Preview + Production futura)
# =============================================================================
# Cliente OAuth Web INDEPENDIENTE del cliente de Calendar.
# Scopes de login: openid email profile (sin Calendar ni offline).
# Genera AUTH_SECRET con: npx auth secret
AUTH_SECRET=ejemplo_auth_secret_cambiar_en_local
AUTH_GOOGLE_ID=1234567890-login.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=ejemplo_auth_google_secret_no_real

# Lista de correos autorizados (coma, trim, lowercase; sin vacíos ni duplicados).
# No revelar estos valores en UI, logs ni commits.
AUTH_ALLOWED_EMAILS=usuario.autorizado@example.com,otro.autorizado@example.com

# trustHost de Auth.js. Usar true en:
# - desarrollo local (localhost);
# - Preview Vercel;
# - Production futura.
# Evita UntrustedHost detrás del proxy de Vercel / host headers.
AUTH_TRUST_HOST=true

# =============================================================================
# Opcionales / diagnóstico local (NO en Vercel)
# =============================================================================
# CALENDAR_TRACE_STAGES=1

# Vida 2.0 - variables de entorno (ejemplo)
#
# Copia este archivo a `.env.local` y completa los valores reales.
# `.env.local` esta ignorado por Git y NUNCA debe subirse al repositorio.
# Todas estas variables se usan solo en el servidor: la clave privada y el
# token de Notion nunca llegan al navegador.

# Origen de datos de Google Sheets: "mock" (por defecto) o "google".
DATA_SOURCE=mock

# Cuenta de servicio de Google con acceso de LECTURA al Sheet DEV.
GOOGLE_SERVICE_ACCOUNT_EMAIL=vida-2-0-dev@tu-proyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio.
# Pega el bloque completo en una sola linea usando \n para los saltos de linea.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...clave-de-ejemplo...\n-----END PRIVATE KEY-----\n"

# ID del Google Sheet DEV (unico ID permitido por la integracion).
GOOGLE_SHEETS_DEV_ID=1TBrEQuocPSNv9SradWea2YWQtMpOEIsHHNRJe0YACdY

# --- Notion (Fase 4A: solo lectura) ---
# Origen: "mock" (por defecto) o "notion".
NOTION_DATA_SOURCE=mock

# Token de integracion interna de Notion (solo servidor). No lo pegues en el repo.
NOTION_API_TOKEN=secret_ejemplo_no_usar_en_produccion

# Data source IDs canonicos (lista blanca). Los valores de ejemplo coinciden
# con las bases Tareas / Proyectos / Areas de Vida 2.0.
NOTION_TASKS_DATA_SOURCE_ID=a19c1f00-7c4b-4920-ae8a-63d3d4e2525a
NOTION_PROJECTS_DATA_SOURCE_ID=a7b11d6e-f324-4fc7-af71-d2d89da71d28
NOTION_AREAS_DATA_SOURCE_ID=9f166408-d1b0-4bdf-a9f4-9c6801d8b750

# --- Google Calendar (Fase 5A: solo lectura, OAuth preparado) ---
# Origen: "mock" (por defecto) o "google".
# No reutiliza la cuenta de servicio de Sheets. Credenciales OAuth de un solo usuario.
GOOGLE_CALENDAR_DATA_SOURCE=mock

# Client ID / Secret de OAuth 2.0 (aplicacion web). Valores ficticios de ejemplo.
GOOGLE_CALENDAR_CLIENT_ID=1234567890-ejemplo.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=ejemplo_client_secret_no_real

# Refresh token obtenido offline (Fase 5B). Solo servidor; nunca al navegador.
GOOGLE_CALENDAR_REFRESH_TOKEN=ejemplo_refresh_token_no_real

# Lista de calendar IDs autorizados (separados por comas). Sin descubrimiento global.
GOOGLE_CALENDAR_IDS=primary

# Zona horaria civil para events.list y adaptacion.
GOOGLE_CALENDAR_TIMEZONE=America/Argentina/Cordoba

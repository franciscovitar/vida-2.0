{
  "name": "vida-2-0",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "npm@11.16.0",
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test \"tests/*.test.ts\"",
    "check": "npm run typecheck && npm run lint && npm run stylelint && npm run format:check",
    "verify": "npm run check && npm run build"
  },
  "dependencies": {
    "googleapis": "^173.0.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard-scss": "17.0.0",
    "tsx": "^4.23.1",
    "typescript": "6.0.3"
  }
}
